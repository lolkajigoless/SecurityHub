<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.scene.Cursor?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Menu?>
<?import javafx.scene.control.MenuBar?>
<?import javafx.scene.control.MenuItem?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.text.TextFlow?>

<AnchorPane id="AnchorPane" prefHeight="419.0" prefWidth="882.0" styleClass="mainFxmlClass" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.mycompany.securityhub.PrincipalController">
    
    <stylesheets>
        <URL value="@styles/tela_principal.css" />
    </stylesheets>
    
   <children>
      <Button fx:id="gerarSenha" layoutX="64.0" layoutY="169.0" mnemonicParsing="false" onAction="#GerarSenha" prefHeight="83.0" prefWidth="194.0" text="Gerar senha forte">
         <cursor>
            <Cursor fx:constant="HAND" />
         </cursor></Button>
      <Button fx:id="VerificarForca" layoutX="344.0" layoutY="168.0" mnemonicParsing="false" onAction="#VerificarForcaSenha" prefHeight="83.0" prefWidth="194.0" text="Verificar força de uma senha">
         <cursor>
            <Cursor fx:constant="HAND" />
         </cursor></Button>
      <Button fx:id="Senhas_Usuario" layoutX="624.0" layoutY="169.0" mnemonicParsing="false" onAction="#MinhasSenhas" prefHeight="83.0" prefWidth="194.0" text="Suas Senhas">
         <cursor>
            <Cursor fx:constant="HAND" />
         </cursor></Button>
      <MenuBar>
        <menus>
          <Menu mnemonicParsing="false" text="Arquivo">
            <items>
              <MenuItem fx:id="menuLogout" mnemonicParsing="false" onAction="#handleLogout" text="LogOut" />
              <MenuItem fx:id="menuSair" mnemonicParsing="false" onAction="#handleSair" text="Sair" />
            </items>
          </Menu>
        </menus>
         <cursor>
            <Cursor fx:constant="HAND" />
         </cursor>
      </MenuBar>
      <HBox layoutX="85.0" layoutY="13.0" />
        <Button fx:id="botaoMostrarEmail" layoutX="538.0" layoutY="45.0" onAction="#alternarEmail" prefHeight="25.0" prefWidth="104.0" text="Mostrar Email">
         <cursor>
            <Cursor fx:constant="HAND" />
         </cursor>
      </Button>
      <TextFlow fx:id="textFlowUsuario" layoutX="107.0" layoutY="20.0" prefHeight="20.0" prefWidth="421.0">
         <cursor>
            <Cursor fx:constant="TEXT" />
         </cursor>
      </TextFlow>
        <Label fx:id="labelEmail" layoutX="538.0" layoutY="20.0" text="Email oculto">
         <font>
            <Font size="14.0" />
         </font>
         <cursor>
            <Cursor fx:constant="TEXT" />
         </cursor>
      </Label>    
   </children>
</AnchorPane>
