<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="510.0" prefWidth="739.0" styleClass="mainFxmlClass" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.mycompany.securityhub.Guardar_senhas">
    <stylesheets>
        <URL value="@styles/login_tela.css" />
    </stylesheets>
   <children>
       <TableView fx:id="tabelaSenhas" layoutX="10.0" layoutY="10.0" prefHeight="400.0" prefWidth="720.0">
          <columns>
            <TableColumn fx:id="colunaServico" prefWidth="231.0" text="Serviço" />
            <TableColumn fx:id="colunaDescricao" prefWidth="258.0" text="Descrição" />
            <TableColumn fx:id="colunaSenha" prefWidth="230.0" text="Senha" />
          </columns>
       </TableView>
      <HBox alignment="CENTER_LEFT" layoutX="10.0" layoutY="423.0" prefHeight="85.0" prefWidth="437.0">
          <Button fx:id="btnAdicionar" text="Adicionar" />
            <Button fx:id="btnEditar" text="Editar" />
            <Button fx:id="btnDeletar" text="Deletar" />
         <Button mnemonicParsing="false" onAction="#gerarDocx" text="Gerar DOCX" />
         <Button mnemonicParsing="false" onAction="#importarDocx" prefHeight="25.0" prefWidth="179.0" text="Dados do .DOCX para a tabela" />
      </HBox>
        <Button layoutX="648.0" layoutY="453.0" mnemonicParsing="false" onAction="#Voltar" prefHeight="25.0" prefWidth="55.0" text="Voltar" />
      <Label layoutX="39.0" layoutY="416.0" prefHeight="27.0" prefWidth="661.0" text="Atenção: os dados não são armazenados. Gere o arquivo .DOCX para garantir que não perca o conteúdo." textFill="RED" wrapText="true">
         <font>
            <Font size="14.0" />
         </font>
      </Label>
   </children>
</AnchorPane>
